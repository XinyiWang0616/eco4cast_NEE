#!/bin/bash



set -e



cd /home/xinyiw/eco4cast



echo "Creating .gitignore..."

cat > .gitignore << 'EOF'

# data files

data/

*.nc

*.h5

*.hdf

*.pkl



# output/log files

*.out

*.err

*.log



# python cache

__pycache__/

.ipynb_checkpoints/



# system files

.DS_Store

EOF



echo "Initializing git repo..."

git init



echo "Adding files..."

git add .



echo "Committing files..."

git commit -m "initial commit"



echo "Setting branch to main..."

git branch -M main



echo "Adding GitHub remote..."

git remote add origin https://github.com/XinyiWang0616/eco4cast_NEE.git



echo "Pushing to GitHub..."

git push -u origin main



echo "Done!"
